// Formula: F(n) = F(n-1) + F(n-2)

// Using while loop
var count = 0;
var a = 0;
var b = 1;

while (count < 10) {
	print a;
	var temp = a + b;
	a = b;
	b = temp;
	count = count + 1;
}

// Using for loop
print "";
var a = 0;
var b = 1;

for (var i = 0; i < 10; i = i + 1) {
	print a;
	var temp = a + b;
	a = b;
	b = temp;
}
